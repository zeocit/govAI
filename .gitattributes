# Normalização de fim de linha (evita ruído de diff entre macOS/Linux/Windows)
* text=auto eol=lf

# Scripts shell sempre LF
*.sh text eol=lf

# ── Git LFS ──────────────────────────────────────────────────────────────────
# Amostras parquet versionadas (a maior parte de dados/ é gitignored; o que for
# versionado intencionalmente em data/samples/ passa por LFS).
*.parquet filter=lfs diff=lfs merge=lfs -text

# Snapshots PDF imutáveis por marco OSF, em references/
*.pdf filter=lfs diff=lfs merge=lfs -text

# Binários diversos
*.bin  filter=lfs diff=lfs merge=lfs -text
*.png  filter=lfs diff=lfs merge=lfs -text
