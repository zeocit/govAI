# .env.example — govAI pipeline_v6
# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA commitar o arquivo .env no repositório.
# O .env já está no .gitignore.

# Chave da API do OpenRouter (usado por 04a e 04b)
# Obter em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Email institucional para o polite pool do OpenAlex (01a)
# Sem este email, a API aplica rate limit mais restritivo.
OPENALEX_EMAIL=seu_email@instituicao.br
