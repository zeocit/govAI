# Copie este arquivo para .env e preencha com valores reais.
# NUNCA versione o .env (ele está no .gitignore).

# Chave da API do OpenRouter, usada na pré-classificação LLM (04a, 04b).
# Formato: sk-or-...
OPENROUTER_API_KEY=

# E-mail para o "polite pool" da API do OpenAlex (01a). Aumenta o rate limit.
OPENALEX_EMAIL=seu_email@instituicao.br
